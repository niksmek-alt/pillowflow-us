{% comment %}PillowFlow floating WhatsApp widget{% endcomment %}

{% liquid
  assign raw_phone = section.settings.phone_number | default: '14157247080'
  assign phone = raw_phone | remove: '+' | remove: ' ' | remove: '-' | remove: '(' | remove: ')' | remove: '.'
  assign message = section.settings.message | url_encode
%}

<style>
  .pf-whatsapp-widget {
    position: fixed;
    right: max(18px, env(safe-area-inset-right));
    bottom: max(18px, env(safe-area-inset-bottom));
    z-index: 50;
  }
  .pf-whatsapp-widget__button {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    min-height: 48px;
    padding: 12px 18px;
    border: 1px solid rgba(15, 23, 42, 0.14);
    border-radius: 999px;
    background: var(--pf-widget-color, #e8673a);
    color: var(--pf-widget-text, #ffffff);
    box-shadow: 0 12px 30px rgba(15, 23, 42, 0.18);
    font: inherit;
    font-size: 14px;
    font-weight: 700;
    line-height: 1;
    text-decoration: none;
    transition: filter 180ms ease, box-shadow 180ms ease, transform 180ms ease;
  }
  .pf-whatsapp-widget__button:hover {
    filter: brightness(0.92);
    box-shadow: 0 14px 34px rgba(15, 23, 42, 0.24);
    transform: translateY(-1px);
  }
  .pf-whatsapp-widget__button:focus-visible {
    outline: 3px solid rgba(232, 103, 58, 0.36);
    outline-offset: 3px;
  }
  .pf-whatsapp-widget__icon { width: 18px; height: 18px; flex: none; }
  @media screen and (max-width: 749px) {
    .pf-whatsapp-widget {
      right: max(12px, env(safe-area-inset-right));
      bottom: max(12px, env(safe-area-inset-bottom));
    }
    .pf-whatsapp-widget__button { min-height: 46px; padding: 11px 16px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .pf-whatsapp-widget__button { transition: none; }
  }
</style>

{% if section.settings.enabled and phone != blank %}
  <aside class="pf-whatsapp-widget" aria-label="Contact {{ shop.name }}" {{ section.shopify_attributes }}>
    <a
      class="pf-whatsapp-widget__button"
      style="--pf-widget-color: {{ section.settings.button_color }}; --pf-widget-text: {{ section.settings.text_color }};"
      href="https://wa.me/{{ phone }}?text={{ message }}"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Start a WhatsApp chat with {{ shop.name }}"
    >
      <svg class="pf-whatsapp-widget__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true">
        <path d="M20.5 11.5a8.5 8.5 0 0 1-12.6 7.4L3 20.5l1.6-4.7A8.5 8.5 0 1 1 20.5 11.5z"/>
        <path d="M8.4 7.7c.2-.4.4-.4.7-.4h.5c.2 0 .3.1.4.4l.7 1.7c.1.3.1.4-.1.6l-.6.7c-.2.2-.2.4 0 .7.5.9 1.3 1.7 2.2 2.2.3.2.5.2.7 0l.7-.8c.2-.2.4-.3.7-.2l1.7.8c.3.1.4.3.4.5 0 .3-.2 1.3-.8 1.8-.5.5-1.2.8-2.1.6-1.1-.2-2.8-.8-4.6-2.5-1.4-1.3-2.3-2.9-2.6-4-.3-1 .1-1.6.4-2.1z"/>
      </svg>
      <span>{{ section.settings.button_label | escape }}</span>
    </a>
  </aside>
{% endif %}

{% schema %}
{
  "name": "WhatsApp widget",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "Show widget", "default": true },
    { "type": "text", "id": "phone_number", "label": "Phone with country code", "default": "14157247080" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Talk to PillowFlow" },
    { "type": "textarea", "id": "message", "label": "Prefilled message", "default": "Hey, I drive long hours. I want to try PillowFlow." },
    { "type": "color", "id": "button_color", "label": "Button color", "default": "#e8673a" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#ffffff" }
  ],
  "presets": [{ "name": "WhatsApp widget" }]
}
{% endschema %}
