PILLOWFLOW_ADMIN_TOKEN=replace-with-a-long-random-secret
PILLOWFLOW_REFERRALS_DB=/data/referrals.db
PILLOWFLOW_HOST=0.0.0.0
PILLOWFLOW_PORT=8000
PILLOWFLOW_TRUST_PROXY=1
PILLOWFLOW_ALLOWED_ORIGINS=https://pillowflow.com,https://www.pillowflow.com,https://pillowflow.us,https://www.pillowflow.us,https://refer.pillowflow.us
PILLOWFLOW_RATE_LIMIT_MAX=5
PILLOWFLOW_RATE_LIMIT_WINDOW=600

# Optional SMTP notification. The API still stores referrals if email delivery fails.
PILLOWFLOW_SMTP_HOST=smtp.example.com
PILLOWFLOW_SMTP_PORT=587
PILLOWFLOW_SMTP_SECURITY=starttls
PILLOWFLOW_SMTP_USER=connect@pillowflow.com
PILLOWFLOW_SMTP_PASSWORD=replace-with-provider-app-password
PILLOWFLOW_SMTP_FROM=connect@pillowflow.com
PILLOWFLOW_NOTIFY_TO=connect@pillowflow.com
