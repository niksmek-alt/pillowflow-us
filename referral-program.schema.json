{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pillowflow.us/schemas/founding-drivers-referral.json",
  "title": "PillowFlow Founding Drivers Referral",
  "description": "Shared referral record for PillowFlow.com and PillowFlow.us.",
  "type": "object",
  "required": ["id", "created_at", "updated_at", "referral_type", "referrer_name", "referrer_email", "source_site", "status", "reward_amount", "payout_status"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "referral_type": { "enum": ["driver_referral", "fleet_referral", "creator_referral"] },
    "referrer_name": { "type": "string" },
    "referrer_email": { "type": "string", "format": "email" },
    "referrer_phone": { "type": ["string", "null"] },
    "referral_code": { "type": ["string", "null"] },
    "referred_name": { "type": ["string", "null"] },
    "referred_email": { "type": ["string", "null"] },
    "referred_phone": { "type": ["string", "null"] },
    "company_name": { "type": ["string", "null"] },
    "company_website": { "type": ["string", "null"] },
    "fleet_size": { "type": ["string", "null"] },
    "decision_maker_name": { "type": ["string", "null"] },
    "decision_maker_contact": { "type": ["string", "null"] },
    "creator_social_link": { "type": ["string", "null"] },
    "creator_audience_type": { "type": ["string", "null"] },
    "creator_audience_size": { "type": ["string", "null"] },
    "reason": { "type": ["string", "null"] },
    "source_site": { "enum": ["pillowflow.com", "pillowflow.us"] },
    "status": { "enum": ["submitted", "reviewing", "approved", "code_created", "converted", "reward_pending", "paid", "rejected"] },
    "reward_amount": { "type": "number", "minimum": 0 },
    "payout_status": { "type": "string", "default": "not_ready" },
    "admin_notes": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
